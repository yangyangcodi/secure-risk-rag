APP_ENV=dev
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Options: ollama | anthropic | vertex | mock
MODEL_PROVIDER=ollama
EMBEDDING_MODEL=all-MiniLM-L6-v2
GEN_MODEL=llama3.2

# Anthropic (only needed when MODEL_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Vertex AI (only needed when MODEL_PROVIDER=vertex)
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

VECTOR_INDEX_PATH=./app/data/faiss.index
DOC_STORE_PATH=./app/data/docstore.json
